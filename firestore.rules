rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: games
    // Document ID: {gameId}
    // Fields:
    //   - status: string ('waiting', 'playing', 'finished')
    //   - hostId: string
    //   - playerIds: list of strings
    //   - playerNames: map
    //   - currentTurnIndex: number
    //   - dice: list of numbers
    //   - kept: list of booleans
    //   - rollsLeft: number
    //   - scores: map
    //   - round: number
    //   - createdAt: timestamp
    //   - updatedAt: timestamp
    //
    // ===============================================================
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isPlayerInGame() {
      return request.auth.uid in resource.data.playerIds;
    }

    function isJoiningGame() {
      return request.resource.data.status == 'waiting' &&
             request.auth.uid in request.resource.data.playerIds &&
             !(request.auth.uid in resource.data.playerIds);
    }

    function isValidGame(data) {
      return data.keys().hasAll(['status', 'hostId', 'playerIds', 'playerNames', 'currentTurnIndex', 'dice', 'kept', 'rollsLeft', 'scores', 'round', 'createdAt', 'updatedAt']) &&
             data.status in ['waiting', 'playing', 'finished'] &&
             data.hostId is string &&
             data.playerIds is list &&
             data.playerIds.size() <= 4 &&
             data.playerNames is map &&
             data.currentTurnIndex is number &&
             data.dice is list && data.dice.size() == 5 &&
             data.kept is list && data.kept.size() == 5 &&
             data.rollsLeft is number && data.rollsLeft >= 0 && data.rollsLeft <= 3 &&
             data.scores is map &&
             data.round is number && data.round >= 1 && data.round <= 14 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /games/{gameId} {
      // Anyone authenticated can read waiting games or games they are in
      allow read: if isAuthenticated() && (resource.data.status == 'waiting' || isPlayerInGame());
      
      // Anyone authenticated can create a game
      allow create: if isAuthenticated() && 
                    isValidGame(request.resource.data) &&
                    request.resource.data.hostId == request.auth.uid &&
                    request.resource.data.playerIds[0] == request.auth.uid &&
                    request.resource.data.playerIds.size() == 1;
                    
      // Players can update the game if it's their turn, or if they are joining
      allow update: if isAuthenticated() && 
                    isValidGame(request.resource.data) &&
                    (
                      isJoiningGame() || 
                      (isPlayerInGame() && resource.data.status == 'playing') ||
                      (isPlayerInGame() && resource.data.status == 'waiting' && request.resource.data.status == 'playing')
                    );
    }
  }
}
