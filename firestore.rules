rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // ===================================
    // YAHTZEE GAME
    // ===================================

    function isPlayerInYahtzee() {
      return isAuthenticated() && request.auth.uid in existing().playerIds;
    }

    function isJoiningYahtzeeGame() {
      return incoming().status == 'waiting' &&
             request.auth.uid in incoming().playerIds &&
             !(request.auth.uid in existing().playerIds);
    }

    function isValidGame(data) {
      return data.keys().hasAll(['status', 'hostId', 'playerIds', 'playerNames', 'currentTurnIndex', 'dice', 'kept', 'rollsLeft', 'scores', 'round', 'createdAt', 'updatedAt']) &&
             data.status in ['waiting', 'playing', 'finished'] &&
             data.hostId is string &&
             data.playerIds is list &&
             data.playerIds.size() <= 4 &&
             data.playerNames is map &&
             data.currentTurnIndex is number &&
             data.dice is list && data.dice.size() == 5 &&
             data.kept is list && data.kept.size() == 5 &&
             data.rollsLeft is number && data.rollsLeft >= 0 && data.rollsLeft <= 3 &&
             data.scores is map &&
             data.round is number && data.round >= 1 && data.round <= 14 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /games/{gameId} {
      allow read: if isAuthenticated() && isValidId(gameId) && (existing().status == 'waiting' || isPlayerInYahtzee());
      
      allow list: if isAuthenticated(); // To allow querying for waiting games

      allow create: if isAuthenticated() && 
                    isValidId(gameId) &&
                    isValidGame(incoming()) &&
                    incoming().hostId == request.auth.uid &&
                    incoming().playerIds[0] == request.auth.uid &&
                    incoming().playerIds.size() == 1;
                    
      allow update: if isAuthenticated() && 
                    isValidId(gameId) &&
                    isValidGame(incoming()) &&
                    (
                      isJoiningYahtzeeGame() || 
                      (isPlayerInYahtzee() && existing().status == 'playing') ||
                      (isPlayerInYahtzee() && existing().status == 'waiting' && incoming().status == 'playing')
                    );
    }

    // ===================================
    // OVERRIDE GAME
    // ===================================

    function isPlayerInOverride() {
      return isAuthenticated() && request.auth.uid in existing().playerIds;
    }

    function isJoiningOverrideGame() {
      return incoming().status == 'waiting' &&
             request.auth.uid in incoming().playerIds &&
             !(request.auth.uid in existing().playerIds);
    }

    function isValidOverrideGame(data) {
      return data.keys().hasAll(['status', 'hostId', 'playerIds', 'playerNames', 'currentTurnIndex', 'direction', 'deck', 'discardPile', 'currentColor', 'hands', 'unoFlags', 'createdAt', 'updatedAt']) &&
             data.status in ['waiting', 'playing', 'finished'] &&
             data.hostId is string &&
             data.playerIds is list &&
             data.playerIds.size() <= 4 &&
             data.playerNames is map &&
             data.currentTurnIndex is number &&
             data.direction is number &&
             data.deck is list &&
             data.discardPile is list &&
             data.currentColor is string &&
             data.hands is map &&
             data.unoFlags is map &&
             (data.winnerId == null || data.winnerId is string) &&
             (data.pendingWildAction == null || data.pendingWildAction is map) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /override_games/{gameId} {
      allow read: if isAuthenticated() && isValidId(gameId) && (existing().status == 'waiting' || isPlayerInOverride());
      
      allow list: if isAuthenticated(); // To allow querying for waiting games
      
      allow create: if isAuthenticated() && 
                    isValidId(gameId) &&
                    isValidOverrideGame(incoming()) &&
                    incoming().hostId == request.auth.uid &&
                    incoming().playerIds[0] == request.auth.uid &&
                    incoming().playerIds.size() == 1;
                    
      allow update: if isAuthenticated() && 
                    isValidId(gameId) &&
                    isValidOverrideGame(incoming()) &&
                    (
                      isJoiningOverrideGame() || 
                      (isPlayerInOverride() && existing().status == 'playing') ||
                      (isPlayerInOverride() && existing().status == 'waiting' && incoming().status == 'playing') ||
                      (isPlayerInOverride() && incoming().status == 'finished')
                    );
    }
  }
}
